@model IEnumerable<AracServis.Models.Kullanicilar>
@{
    ViewData["Title"] = "Personel ve Müşteri Yönetimi";
    var aktifKullaniciId = Context.Session.GetInt32("KullaniciID");
}

<div class="container mt-5">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-people-fill"></i> Sistemdeki Aktif Kullanıcılar</h4>
            <span class="badge bg-success">Toplam: @Model.Count() Kişi</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Ad Soyad</th>
                            <th>Kullanıcı Adı</th>
                            <th>Rol / Departman</th>
                            <th>Durum</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr><td colspan="5" class="text-center py-4">Sistemde aktif kullanıcı bulunmuyor.</td></tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@item.AdSoyad</td>
                                <td class="text-muted">@@@item.KullaniciAdi</td>
                                <td>
                                    @if (item.Rol?.RolAdi == "İşletme Sahibi")
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-star-fill"></i> Yönetici</span>
                                    }
                                    else if (item.Rol?.RolAdi == "Çalışan")
                                    {
                                        <span class="badge bg-info text-dark"><i class="bi bi-wrench-adjustable-circle"></i> Mekanik Personel</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-person"></i> Müşteri</span>
                                    }
                                </td>
                                <td><span class="badge bg-success rounded-pill">Aktif</span></td>
                                <td class="text-end pe-4">
                                    @if (item.KullaniciId == aktifKullaniciId)
                                    {
                                        <button class="btn btn-sm btn-outline-secondary disabled" title="Kendi hesabınız">
                                            <i class="bi bi-shield-lock"></i> Sen
                                        </button>
                                    }
                                    else
                                    {
                                        <form asp-action="PasifeAl" asp-route-id="@item.KullaniciId" method="post" class="d-inline"
                                              onsubmit="return confirm('@item.AdSoyad isimli kişinin sisteme erişimini kesmek istediğinize emin misiniz? (Geçmiş işlemleri silinmez)');">
                                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                                <i class="bi bi-power"></i> Pasife Al
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>