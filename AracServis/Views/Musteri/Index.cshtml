@using AracServis.Models
@model IEnumerable<AracServis.Models.IsEmirleri>
@{
    ViewData["Title"] = "Araçlarım ve İşlemler";
}

<div class="container-fluid mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">
            <i class="bi bi-car-front-fill text-primary me-2"></i> Servisteki Araçlarım
        </h2>
        <a asp-action="RandevuAl" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
            <i class="bi bi-calendar-plus me-1"></i> Yeni Randevu Al
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4 py-3">Araç Plakası</th>
                            <th>Servis Giriş Tarihi</th>
                            <th>Anlık Durum</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-info-circle display-4 d-block mb-3 text-secondary"></i>
                                    Şu anda serviste kayıtlı bir aracınız bulunmuyor.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold fs-5 text-dark">
                                        <span class="badge bg-light text-dark border shadow-sm px-3 py-2">
                                            TR | @item.AracPlaka
                                        </span>
                                    </td>
                                    
                                    <td>
                                        <i class="bi bi-calendar-check text-primary me-1"></i> @item.AcilisTarihi?.ToString("dd MMMM yyyy HH:mm")
                                    </td>

                                    <td>
                                        @{
                                            string badgeClass = "bg-secondary";
                                            if (item.Durum == IsEmriDurumu.Bekliyor) badgeClass = "bg-warning text-dark";
                                            else if (item.Durum == IsEmriDurumu.Islemde) badgeClass = "bg-primary";
                                            else if (item.Durum == IsEmriDurumu.Tamamlandi) badgeClass = "bg-success";
                                            else if (item.Durum == IsEmriDurumu.TeslimEdildi) badgeClass = "bg-dark";
                                        }
                                        <span class="badge @badgeClass px-3 py-2 shadow-sm" style="font-size: 0.9rem;">
                                            @(item.DurumBilgisi?.DurumAdi ?? "Bilinmiyor")
                                        </span>
                                    </td>

                                    <td class="text-end pe-4">
                                        <a asp-action="AracDetay" asp-route-id="@item.IsEmriId" class="btn btn-outline-primary btn-sm rounded-pill fw-bold px-3 shadow-sm">
                                            <i class="bi bi-search me-1"></i> Fatura ve Detay
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>