@* MÜŞTERİ YENİ ŞİKAYET / RANDEVU FORMU
    Model olarak "Randevu" tablosunu kullanıyoruz çünkü formdan gelen veriler bu tabloya kaydedilecek.
*@
@model AracServis.Models.Randevu

@{
    ViewData["Title"] = "Yeni Şikayet / Randevu Oluştur";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            
            <div class="card shadow-lg border-0 rounded-4">
                
                <div class="card-header bg-primary text-white p-4 rounded-top-4">
                    <h3 class="mb-0 fw-bold"><i class="bi bi-tools me-2"></i> Yeni Arıza Kaydı Oluştur</h3>
                    <small class="text-white-50">Aracınızdaki sorunu bize detaylıca iletin.</small>
                </div>

                <div class="card-body p-5">
                    
                    @* ÇOK ÖNEMLİ: enctype="multipart/form-data"
                        Eğer bir formda "Fotoğraf/Dosya Yükleme" işlemi varsa bu kodu YAZMAK ZORUNDASINIZ!
                        Yoksa fotoğraf Controller'a "null" (boş) olarak gider, sistem çöker.
                    *@
                    <form asp-action="YeniTalep" method="post" enctype="multipart/form-data">
                        
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label asp-for="AracPlaka" class="form-label fw-bold text-muted small">ARAÇ PLAKASI</label>
                            <div class="input-group input-group-lg shadow-sm">
                                <span class="input-group-text bg-white border-end-0 text-primary fw-bold">TR</span>
                                @* asp-for="AracPlaka": Bu input'un veritabanındaki AracPlaka sütununa bağlanacağını belirtir *@
                                <input asp-for="AracPlaka" class="form-control border-start-0 text-uppercase fw-bold" placeholder="Örn: 07 ABC 123" required autocomplete="off" />
                            </div>
                            <span asp-validation-for="AracPlaka" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="SikayetAciklamasi" class="form-label fw-bold text-muted small">ŞİKAYETİNİZ / ARIZA DETAYI</label>
                            @* Kullanıcı uzun metin yazabilsin diye textarea (metin kutusu) kullanıyoruz *@
                            <textarea asp-for="SikayetAciklamasi" class="form-control form-control-lg bg-light border-0 shadow-sm" rows="5" placeholder="Aracınızdaki sorunu, nereden ses geldiğini veya talebinizi detaylıca anlatın..." required></textarea>
                            <span asp-validation-for="SikayetAciklamasi" class="text-danger small"></span>
                        </div>

                        <div class="mb-5 p-4 border rounded-3 bg-light text-center border-dashed">
                            <i class="bi bi-cloud-arrow-up text-primary" style="font-size: 3rem;"></i>
                            <h5 class="mt-2 fw-bold text-dark">Arıza Görseli Yükle (İsteğe Bağlı)</h5>
                            <p class="text-muted small mb-3">Vuruk, kırık veya uyarı lambasının fotoğrafını çekip yükleyebilirsiniz.</p>
                            
                            @* name="arizaGorseli": Controller'daki metodun (IFormFile arizaGorseli) parametresiyle BİREBİR AYNI olmalıdır!
                                accept="image/*": Telefon veya bilgisayarda sadece "Resim/Galeri" klasörünün açılmasını sağlar, PDF falan seçtirmez.
                            *@
                            <input type="file" name="arizaGorseli" id="arizaGorseli" class="form-control" accept="image/*" />
                            
                            <div class="mt-2 text-success small fw-bold">
                                <i class="bi bi-shield-check"></i> Yüklenen görseller sistemimiz tarafından otomatik olarak optimize edilir (800px).
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
                                <i class="bi bi-arrow-left"></i> Vazgeç
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg fw-bold rounded-pill px-5 shadow">
                                <i class="bi bi-send-fill"></i> Talebi Gönder
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@* Doğrulama (Validation) scriptlerini sayfaya dahil ediyoruz ki form boş gönderilirse sayfa yenilenmeden uyarı versin *@
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}