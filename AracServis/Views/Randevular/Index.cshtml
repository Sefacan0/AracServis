@using AracServis.Models
@model IEnumerable<AracServis.Models.Randevu>
@{
    ViewData["Title"] = "Randevu Talepleri";
}

<div class="container-fluid mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">
            <i class="bi bi-calendar-check text-primary me-2"></i> Gelen Randevu Talepleri
        </h2>
    </div>

    <div class="alert alert-info shadow-sm border-0 d-flex align-items-center mb-4">
        <i class="bi bi-info-circle-fill fs-4 me-3"></i>
        <div>
            Müşterilerin web üzerinden oluşturduğu randevular buraya düşer. Onayladığınız randevular otomatik olarak <strong>Atölye (İş Emirleri)</strong> listesine "Bekliyor" statüsünde aktarılacaktır.
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4 py-3">Talep Tarihi</th>
                            <th>Müşteri Bilgisi</th>
                            <th>Araç Plaka</th>
                            <th>Müşteri Notu</th>
                            <th>Arıza Görseli</th>
                            <th>Durum</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-calendar-x display-4 d-block mb-3 text-secondary"></i>
                                    Bekleyen veya geçmiş bir randevu talebi bulunmuyor.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.OrderByDescending(r => r.TalepTarihi))
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark">
                                        <i class="bi bi-calendar-event me-1 text-primary"></i>
                                        @item.TalepTarihi.ToString("dd MMM yyyy") <br />
                                        <small class="text-muted"><i class="bi bi-clock me-1"></i> @item.TalepTarihi.ToString("HH:mm")</small>
                                    </td>
                                    
                                    <td class="fw-bold">
                                        <i class="bi bi-person-fill me-1 text-muted"></i> @(item.Musteri?.AdSoyad ?? "Bilinmeyen Müşteri")
                                    </td>

                                    <td>
                                        <span class="badge bg-light text-dark border shadow-sm px-2 py-1 fs-6">
                                            TR | @item.AracPlaka
                                        </span>
                                    </td>

                                    <td>
                                        @{
                                            string not = item.SikayetAciklamasi ?? "-";
                                            string kisaNot = not.Length > 30 ? not.Substring(0, 30) + "..." : not;
                                        }
                                        <span title="@not" style="cursor: help;">
                                            <i class="bi bi-chat-left-text text-muted me-1"></i> @kisaNot
                                        </span>
                                    </td>
                                    
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.ArizaGorselYolu))
                                        {
                                            <a href="@item.ArizaGorselYolu" target="_blank" title="Büyük halini görmek için tıklayın">
                                                <img src="@item.ArizaGorselYolu" alt="Arıza Görseli" class="rounded shadow-sm" style="width: 50px; height: 50px; object-fit: cover; border: 2px solid #dee2e6;" />
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-muted border px-2 py-1">
                                                <i class="bi bi-image me-1"></i> Görsel Yok
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        @{
                                            string badgeClass = "bg-secondary";

                                            if (item.Durum == RandevuDurumu.OnayBekliyor) { badgeClass = "bg-warning text-dark"; }
                                            else if (item.Durum == RandevuDurumu.Islemde) { badgeClass = "bg-success"; }
                                            else if (item.Durum == RandevuDurumu.Reddedildi) { badgeClass = "bg-danger"; }
                                        }
                                        <!-- HOCANIN İSTEDİĞİ LOOKUP VERİSİ -->
                                        <span class="badge @badgeClass px-3 py-2 shadow-sm">
                                            @(item.DurumBilgisi?.DurumAdi ?? "Bilinmiyor")
                                        </span>
                                    </td>
                                    
                                    <td class="text-end pe-4">
                                        @if (item.Durum == RandevuDurumu.OnayBekliyor)
                                        {
                                            <div class="btn-group shadow-sm">
                                                <form asp-action="Onayla" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@item.RandevuId" />
                                                    <button type="submit" class="btn btn-sm btn-success fw-bold">
                                                        <i class="bi bi-check-lg"></i> Onayla
                                                    </button>
                                                </form>

                                                <form asp-action="Reddet" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@item.RandevuId" />
                                                    <button type="submit" class="btn btn-sm btn-danger fw-bold" onclick="return confirm('Emin misiniz?');">
                                                        <i class="bi bi-x-lg"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                        else
                                        {
                                            <form asp-action="Delete" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@item.RandevuId" />
                                                <button type="submit" class="btn btn-sm btn-outline-secondary" onclick="return confirm('Sistemden silmek istediğinize emin misiniz?');">
                                                    <i class="bi bi-trash3"></i> Sil
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>