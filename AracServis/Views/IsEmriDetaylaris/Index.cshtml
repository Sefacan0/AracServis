@model IEnumerable<AracServis.Models.IsEmriDetaylari>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.YapilanIslem)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Fiyat)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsDeleted)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsEmri)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.YapilanIslem)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Fiyat)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsDeleted)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsEmri.IsEmriId)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.DetayId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.DetayId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.DetayId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
