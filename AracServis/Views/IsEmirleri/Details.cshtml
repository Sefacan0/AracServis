@using AracServis.Models
@model AracServis.Models.IsEmirleri
@{
    ViewData["Title"] = "İş Emri Detayları ve Fatura";
}

<div class="container-fluid mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">
            <i class="bi bi-clipboard2-pulse text-primary me-2"></i> Araç İşlem Masası
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 fw-bold shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Garaja Dön
        </a>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 rounded-4 h-100 border-top border-dark border-5">
                <div class="card-header bg-white p-3 text-center border-bottom-0 pt-4">
                    <h3 class="mb-0 text-uppercase fw-bold" style="letter-spacing: 2px;">
                        TR | @Model.AracPlaka
                    </h3>
                    <span class="badge bg-dark mt-2 px-3 py-2">İş Emri #@Model.IsEmriId</span>
                </div>
                <div class="card-body p-4">
                    
                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                            <span class="text-muted"><i class="bi bi-person-fill me-2"></i>Müşteri:</span>
                            <span class="fw-bold text-dark">@(Model.Musteri?.AdSoyad ?? "Bilinmiyor")</span>
                        </li>
                        <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                            <span class="text-muted"><i class="bi bi-calendar-event me-2"></i>Giriş Tarihi:</span>
                            <span class="fw-bold">@Model.AcilisTarihi?.ToString("dd MMM yyyy HH:mm")</span>
                        </li>
                        <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                            <span class="text-muted"><i class="bi bi-info-circle-fill me-2"></i>Durum:</span>
                            @{
                                string textClass = "text-secondary";
                                string durumMetni = "Bilinmiyor";

                                if (Model.Durum == IsEmriDurumu.Bekliyor) { textClass = "text-warning"; durumMetni = "Bekliyor"; }
                                else if (Model.Durum == IsEmriDurumu.Islemde) { textClass = "text-primary"; durumMetni = "İşlemde"; }
                                else if (Model.Durum == IsEmriDurumu.Tamamlandi) { textClass = "text-success"; durumMetni = "Tamamlandı"; }
                                else if (Model.Durum == IsEmriDurumu.TeslimEdildi) { textClass = "text-dark"; durumMetni = "Teslim Edildi"; }
                            }
                            <span class="fw-bold @textClass">@durumMetni</span>
                        </li>
                    </ul>

                    <div class="alert alert-secondary border-0 shadow-sm rounded-3">
                        <h6 class="fw-bold mb-2"><i class="bi bi-chat-left-text-fill me-2"></i>İlk Kayıt Şikayeti</h6>
                        <p class="mb-0 small">
                            @if (Model.IsEmriDetaylaris.Any(d => d.YapilanIslem.Contains("MÜŞTERİ ŞİKAYETİ")))
                            {
                                @Model.IsEmriDetaylaris.FirstOrDefault(d => d.YapilanIslem.Contains("MÜŞTERİ ŞİKAYETİ"))?.YapilanIslem
                            }
                            else
                            {
                                <em>Müşteri şikayeti belirtilmemiş.</em>
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8 mb-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-header bg-light p-4 border-bottom rounded-top-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-plus-circle-fill text-success me-2"></i>Yeni Parça / İşçilik Ekle</h5>
                    
                    @if (Model.Durum == IsEmriDurumu.Islemde)
                    {
                        <form asp-action="IslemEkle" method="post" class="row g-3">
                            <input type="hidden" name="isEmriId" value="@Model.IsEmriId" />
                            
                            <div class="col-md-7">
                                <div class="form-floating">
                                    <input type="text" class="form-control fw-bold" id="yapilanIslem" name="yapilanIslem" placeholder="Değişen parça veya yapılan işlem" required autocomplete="off">
                                    <label for="yapilanIslem">Yapılan İşlem / Kullanılan Parça Adı</label>
                                </div>
                            </div>
                            <div class="col-md-5">
                                <div class="form-floating input-group">
                                    <input type="number" step="0.01" class="form-control fw-bold text-success" id="fiyat" name="fiyat" placeholder="Tutar" required>
                                    <label for="fiyat">Tutar (₺)</label>
                                    <button class="btn btn-primary px-3 fw-bold" type="submit"><i class="bi bi-plus-lg"></i> Ekle</button>
                                </div>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0 border-0 shadow-sm">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <strong>Dikkat:</strong> Yeni parça ve fiyat ekleyebilmek için aracın durumunu garaj listesinden <b>"İşlemde"</b> olarak güncellemelisiniz.
                        </div>
                    }
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th class="ps-4 py-3">İşlem / Parça Detayı</th>
                                    <th class="text-end">Fiyat</th>
                                    <th class="text-center pe-4" style="width: 80px;">Sil</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detay in Model.IsEmriDetaylaris.Where(d => !d.YapilanIslem.Contains("MÜŞTERİ ŞİKAYETİ")))
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-dark">
                                            <i class="bi bi-wrench-adjustable-circle text-muted me-2"></i>@detay.YapilanIslem
                                        </td>
                                        <td class="text-end fw-bold text-success fs-5">
                                            @detay.Fiyat.ToString("N2") ₺
                                        </td>
                                        <td class="text-center pe-4">
                                            @if (Model.Durum == IsEmriDurumu.Islemde)
                                            {
                                                <form asp-controller="IsEmriDetaylaris" asp-action="Delete" asp-route-id="@detay.DetayId" method="post" class="m-0 p-0">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0 shadow-none" onclick="return confirm('Bu işlemi faturadan silmek istediğinize emin misiniz?');" title="Hatalı işlemi sil">
                                                        <i class="bi bi-trash3-fill fs-5"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <i class="bi bi-lock-fill text-muted" title="Araç işlemde olmadığı için silinemez"></i>
                                            }
                                        </td>
                                    </tr>
                                }
                                @if (!Model.IsEmriDetaylaris.Any(d => !d.YapilanIslem.Contains("MÜŞTERİ ŞİKAYETİ")))
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-4 text-muted">
                                            <i class="bi bi-info-circle me-1"></i> Henüz bu araca işçilik veya parça girilmemiştir.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="bg-light border-top border-2">
                                <tr>
                                    <td class="ps-4 py-4 fw-bold fs-4 text-end">GENEL TOPLAM :</td>
                                    <td colspan="2" class="text-end pe-4 py-4 fw-bold display-6 text-danger">
                                        @ViewBag.ToplamFatura?.ToString("N2") ₺
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>